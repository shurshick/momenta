APP_NAME=Momenta
APP_ENV=development
APP_VERSION=0.1.0

API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+psycopg://momenta:momenta_password@localhost:5432/momenta
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change_me_jwt_secret_32charsminimum!
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

CORS_ORIGINS=http://localhost:3000,http://localhost:8000

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=momenta-media
S3_REGION=us-east-1
S3_SECURE=false

MEDIA_MAX_IMAGE_MB=15
MEDIA_MAX_VIDEO_MB=80
MEDIA_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
MEDIA_ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_HOUR=20

WORKER_CONCURRENCY=2
